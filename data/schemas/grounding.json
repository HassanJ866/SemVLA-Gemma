{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GroundingOutput",
  "type": "object",
  "required": ["object", "bbox"],
  "additionalProperties": false,
  "properties": {
    "object": {
      "type": "string",
      "description": "Name of the target object"
    },
    "bbox": {
      "type": "array",
      "description": "Bounding box [x1, y1, x2, y2] in pixel coordinates",
      "items": {"type": "number"},
      "minItems": 4,
      "maxItems": 4
    }
  }
}
